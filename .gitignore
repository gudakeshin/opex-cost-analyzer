# Secrets — NEVER commit
.env
*.env.local

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/
.coverage

# Data — session uploads and outputs contain client data
data/uploads/
data/outputs/
data/memory/

# Data — app-generated runtime state (not source)
data/engagements/
data/calibration/
data/benchmarks/
data/audit.log

# Claude Code session state
.claude/

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
node_modules/

# OS / IDE
.DS_Store
.idea/
.vscode/
.cursor/
*.swp

# Microsoft Office lock files (created when a doc is open; should never be committed)
~$*

# Large binary assets — use git-lfs or external storage instead of committing directly
*.pptx
*.xlsx
*.docx
# Exceptions: small intentional fixtures and shipped deliverables
!tests/fixtures/**/*.xlsx
!tests/fixtures/**/*.docx
!tests/eval/golden/**/*.xlsx
!tests/eval/golden/**/*.docx
!data/samples/*.xlsx
!deliverables/*.pptx
