{
  "version": "1.0",
  "description": "Per-skill LLM capability levels for each operating mode (M1/M2/M3).",
  "modes": {
    "M1": {
      "label": "Deterministic-only",
      "llm_available": false,
      "description": "No LLM calls. All skills run on deterministic algorithms. Narrative synthesis and peer disclosure mining are unavailable."
    },
    "M2": {
      "label": "Regional Managed LLM",
      "llm_available": true,
      "description": "Anthropic Claude via Bedrock-Mumbai / Azure-India / Anthropic-India. Zero-retention API endpoints required."
    },
    "M3": {
      "label": "On-prem LLM (Ollama)",
      "llm_available": true,
      "description": "Local Llama 3 / Mistral via Ollama. Data never leaves the client VPC. Quality is lower than M2 for complex reasoning tasks."
    }
  },
