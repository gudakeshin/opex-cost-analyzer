MAX_UPLOAD_MB=50

# ⚠️  NEVER commit real API keys. Replace placeholders below with your own keys.
ANTHROPIC_API_KEY=sk-ant-api03-<your-anthropic-api-key-here>

# Gemini provider (replaces Claude when LLM_PROVIDER=gemini)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash       # override if the model ID differs
LLM_PROVIDER=gemini                  # "gemini" | "anthropic" — auto-selects gemini when GEMINI_API_KEY is set
ANTHROPIC_MODEL=claude-sonnet-4-6    # default Claude model when LLM_PROVIDER=anthropic
LLM_CHAT_SYNTHESIS_ENABLED=true      # LLM writes chat answers (provider-agnostic, Claude default); set false to force the deterministic keyword composer

# Qdrant vector memory — self-hosted (see docker-compose.yml for local setup)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                   # Leave blank for local; set for cloud/secured deployment
QDRANT_ENABLED=true
EMBEDDING_MODEL=all-MiniLM-L6-v2     # Local model, no API cost

# Rate limiting & timeouts
OPAR_RATE_LIMIT=10/minute
OPAR_TIMEOUT_SECONDS=240              # full chat/analysis loop (agent + reflect synthesis)
LLM_SYNTHESIS_TIMEOUT_SECONDS=90      # standard Claude advisory/chat synthesis
LLM_THINKING_TIMEOUT_SECONDS=180        # extended-thinking synthesis (Thinking: on)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Optional Redis — distributed manifest locking + session/progress stores (multi-worker production)
# REDIS_URL=redis://localhost:6379/0

# LlamaParse — multimodal PDF/DOCX parsing (https://cloud.llamaindex.ai/)
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key-here
LLAMAPARSE_ENABLED=true
LLAMAPARSE_RESULT_TYPE=markdown
LLAMAPARSE_PREMIUM_MODE=false

